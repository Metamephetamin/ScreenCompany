generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RiskLevel {
  low
  medium
  high
}

enum CompanyStatus {
  ACTIVE
  LIQUIDATION
  INACTIVE
  BANKRUPTCY
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  name            String?
  image           String?
  createdAt       DateTime  @default(now())
  accounts        Account[]
  sessions        Session[]
  checks          Check[]
  monitoringItems MonitoringItem[]
  subscriptions   Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id                  String        @id
  name                String
  shortName           String
  type                String
  inn                 String        @unique
  ogrn                String        @unique
  registrationDate    DateTime
  status              CompanyStatus
  address             String
  director            String
  okved               String
  authorizedCapital   Int?
  massAddress         Boolean       @default(false)
  directorChangesYear Int           @default(0)
  checks              Check[]
  monitoringItems     MonitoringItem[]
  reports             Report[]
}

model Check {
  id        String    @id @default(cuid())
  userId    String?
  companyId String
  reportId  String    @unique
  score     Int
  level     RiskLevel
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])
  report    Report    @relation(fields: [reportId], references: [id])
}

model Report {
  id              String   @id
  companyId       String
  summary         String
  score           Int
  level           RiskLevel
  reasonsJson     Json
  recommendations Json
  sourcesJson     Json
  createdAt       DateTime @default(now())
  company         Company  @relation(fields: [companyId], references: [id])
  check           Check?
}

model MonitoringItem {
  id        String   @id @default(cuid())
  userId    String?
  companyId String
  active    Boolean  @default(true)
  lastCheckedAt DateTime?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
  events    MonitoringEvent[]

  @@unique([userId, companyId])
}

model MonitoringEvent {
  id               String         @id
  monitoringItemId String
  title            String
  severity         RiskLevel
  eventDate        DateTime
  source           String?
  fingerprint      String
  createdAt        DateTime       @default(now())
  monitoringItem   MonitoringItem @relation(fields: [monitoringItemId], references: [id])

  @@unique([monitoringItemId, fingerprint])
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  plan           String
  checksLimit    Int
  monitoringLimit Int
  provider       String?
  providerRef    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}
